# Pedofinder Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# AI/LLM Configuration
# =============================================================================

# LiteLLM model selection
# Options: gpt-4o-mini, gpt-4o, claude-3-5-sonnet-20241022, ollama/llama3.2
LITELLM_MODEL=gpt-4o-mini

# OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (if using Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Local LLM URL (if using Ollama or other local models)
LOCAL_LLM_URL=http://localhost:11434

# Embedding model for vector search
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Appwrite Configuration
# =============================================================================

APPWRITE_ENDPOINT=https://appwrite.blackleafdigital.com/v1
APPWRITE_PROJECT_ID=691779a3003300288357
APPWRITE_API_KEY=your-appwrite-api-key-here

# Appwrite database and collection IDs (will be created if not exist)
APPWRITE_DATABASE_ID=pedofinder
APPWRITE_DOCUMENTS_COLLECTION=documents
APPWRITE_ENTITIES_COLLECTION=entities
APPWRITE_RELATIONSHIPS_COLLECTION=relationships

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database path (relative to project root)
SQLITE_DB_PATH=./data/pedofinder.db

# LanceDB path (relative to project root)
LANCEDB_PATH=./data/lancedb

# Vector embedding dimension (1536 for OpenAI text-embedding-3-small)
VECTOR_DIM=1536

# =============================================================================
# Pinecone Configuration
# =============================================================================

# Pinecone API key
PINECONE_API_KEY=your-pinecone-api-key-here

# Pinecone index name
PINECONE_INDEX_NAME=epstein-docs

# Pinecone environment/cloud
PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# PDF Processing Configuration
# =============================================================================

# Google Pinpoint collection ID
PINPOINT_COLLECTION_ID=092314e384a58618

# Document storage paths
RAW_PDF_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed
CACHE_PATH=./data/cache

# Chunking configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# OCR configuration
OCR_LANGUAGE=eng
OCR_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# Processing Configuration
# =============================================================================

# Batch processing
BATCH_SIZE=10
MAX_WORKERS=4

# Rate limiting for API calls (requests per minute)
API_RATE_LIMIT=60

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY=1.0

# =============================================================================
# Web API Configuration
# =============================================================================

# Server configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API security
API_KEY_REQUIRED=false
API_KEY=your-api-key-here

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# Log file path
LOG_FILE=./logs/pedofinder.log

# =============================================================================
# Development Configuration
# =============================================================================

# Enable debug mode
DEBUG=false

# Enable verbose output
VERBOSE=false

# Enable hot reload for web server
RELOAD=false
