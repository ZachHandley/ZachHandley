---
import Layout from '../layouts/Layout.astro';
import LinkApp from '~/components/svelte/LinkApp.svelte';
import { AppwriteServer } from "~/server/appwriteServer";

const appwriteServer = new AppwriteServer();
const rawLinks = await appwriteServer.listPublished();
const links = rawLinks.map(doc => ({
  name: doc.title,
  url: doc.url,
  icon: doc.icon || undefined,
  type: doc.type as any,
  category: doc.category || undefined,
  active: doc.active,
  order: doc.order,
}));
---

<Layout title="Home" description="Use Steve the dragon to navigate my site">
  <main class="w-full min-h-screen min-w-screen relative bg-gray-900">
    <LinkApp client:only="svelte" {links} />
  </main>
</Layout>
