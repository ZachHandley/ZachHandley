# Website environment variables.
# Copy to `.env` for local dev. In production, set via `wrangler secret put` or Cloudflare Pages env.

# --- Public (client + server) ---
# Defaults are declared in src/env.ts; override here only if you need a different value.
APPWRITE_ENDPOINT=https://appwrite.blackleafdigital.com/v1
APPWRITE_PROJECT_ID=68c3bb35001fe37018e4
SESSION_COOKIE_NAME=a_session_68c3bb35001fe37018e4
APPWRITE_DATABASE_ID=main
COLL_LINKS=links
BUCKET_FILES=files
PRODUCTION_ENABLED=false

# --- Server-only secrets ---
# REQUIRED in production for /api/links and /admin to work.
APPWRITE_API_KEY=
# Read by src/server/getAppwriteClient.ts when useSessionKey=true.
# Not declared in src/env.ts schema yet (see follow-ups).
APPWRITE_SESSION_KEY=

# --- Cloudflare-side requirements (not env vars, listed for setup reference) ---
# - KV namespace `ZSESSION` (id df4e65f081824d0cb86b29afb2a83f60) — bound in wrangler.toml.
# - Appwrite project / database / collection per website/appwrite.config.json.
# - Admin user must have label `admin` for /admin and /api/links to authorize.
